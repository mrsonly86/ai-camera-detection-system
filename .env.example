# Application Configuration
APP_NAME=AI_Camera_Detection_System
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-here
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
DATABASE_URL=sqlite:///./ai_camera_detection.db
POSTGRES_URL=postgresql://user:password@localhost:5432/ai_camera_db
REDIS_URL=redis://localhost:6379/0

# AI Model Configuration
YOLO_MODEL_PATH=./models/yolov5s.pt
FACE_MODEL_PATH=./models/face_recognition_model.pkl
GENDER_MODEL_PATH=./models/gender_model.pkl
AGE_MODEL_PATH=./models/age_model.pkl

# Camera Configuration
CAMERA_INDEX=0
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_FPS=30

# Security Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256
ENCRYPTION_KEY=your-encryption-key-here

# External API Configuration (Mock)
POLICE_API_URL=http://localhost:8001/api/v1
INTERPOL_API_URL=http://localhost:8002/api/v1
POLICE_API_KEY=mock-police-api-key
INTERPOL_API_KEY=mock-interpol-api-key

# Performance Settings
MAX_WORKERS=4
BATCH_SIZE=8
GPU_ENABLED=true
TENSORRT_ENABLED=false

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Storage Configuration
UPLOAD_DIR=./uploads
MODEL_DIR=./models
CACHE_DIR=./cache